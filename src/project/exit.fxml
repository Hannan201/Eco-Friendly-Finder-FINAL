                  <Button id="exitButton" fx:id="exitButton" alignment="BOTTOM_CENTER" mnemonicParsing="false" onAction="#exitProgram" prefHeight="31.0" prefWidth="51.0" style="-fx-background-color: #0800f7; -fx-background-radius: 0;" text="Exit" textAlignment="CENTER" textFill="WHITE" />
