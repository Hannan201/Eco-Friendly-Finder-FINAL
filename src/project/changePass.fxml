<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<?import javafx.scene.control.PasswordField?>
<VBox maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="165.0" prefWidth="372.0" style="-fx-background-color: #242424;" xmlns="http://javafx.com/javafx/16" xmlns:fx="http://javafx.com/fxml/1">
   <children>
      <HBox alignment="CENTER" prefHeight="58.0" prefWidth="372.0">
         <children>
            <PasswordField fx:id="oldPassword" prefHeight="43.0" prefWidth="336.0" promptText="Enter old password" style="-fx-background-color: #ffffff;" />
         </children>
      </HBox>
      <HBox alignment="CENTER" prefHeight="49.0" prefWidth="372.0">
         <children>
            <PasswordField fx:id="newPassword" prefHeight="43.0" prefWidth="336.0" promptText="Enter new password" style="-fx-background-color: #ffffff;" />
         </children>
      </HBox>
      <HBox alignment="CENTER" prefHeight="58.0" prefWidth="372.0" spacing="25.0">
         <children>
            <Button mnemonicParsing="false" onAction="#changePass" prefHeight="35.0" prefWidth="145.0" style="-fx-background-color: blue; -fx-background-radius: 0;" text="Change Password" textFill="WHITE">
               <font>
                  <Font name="System Bold" size="15.0" />
               </font>
            </Button>
            <Button layoutX="10.0" layoutY="10.0" mnemonicParsing="false" onAction="#closeWindow" prefHeight="35.0" prefWidth="145.0" style="-fx-background-color: red; -fx-background-radius: 0;" text="Cancel" textFill="WHITE">
               <font>
                  <Font name="System Bold" size="15.0" />
               </font>
            </Button>
         </children>
      </HBox>
   </children>
</VBox>
